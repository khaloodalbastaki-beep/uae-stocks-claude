# ─────────────────────────────────────────────────────────────────────────────
# Mizan LLM config — pick ONE provider (all free; none need a credit card).
# Verified 2026-06-18. Mizan needs the model to READ real sources, so a GROUNDED
# lane (Gemini / Ollama-Cloud web-search) gives the truest figures.
# ─────────────────────────────────────────────────────────────────────────────

# ── RECOMMENDED: Gemini (AI Studio) — free, no card, built-in Google-Search grounding ──
# Key (free, Google account, no card): https://aistudio.google.com/apikey
MIZAN_PROVIDER=gemini
GEMINI_API_KEY=
# MIZAN_MODEL=gemini-2.0-flash          # gemini-2.5-flash / 3.5-flash also fine

# ── STRONGER: Ollama Cloud — big cloud models (gpt-oss:120b, qwen3-coder:480b, ──
#    deepseek-v3.1:671b, kimi-k2:1t, glm-4.6). Free tier; key (no card):
#    https://ollama.com/settings/keys   (limits are GPU-time based, 1 concurrent)
# MIZAN_PROVIDER=ollama
# OLLAMA_HOST=https://ollama.com
# OLLAMA_API_KEY=
# MIZAN_MODEL=gpt-oss:120b              # or kimi-k2:1t / deepseek-v3.1:671b / qwen3-coder:480b
#   NOTE: cloud models reason strongly but don't auto-web-search in chat-completions —
#   best when given fetched filing text; pair with Gemini for grounded discovery.


# ── GEMINI-FREE grounded (recommended if no Gemini key): Mizan fetches the real filing/IR
#    page (headless Chromium) + Wikipedia itself, then gpt-oss:120b extracts. No key, no quota.
# MIZAN_PROVIDER=ollama
# OLLAMA_HOST=http://localhost:11434
# MIZAN_MODEL=gpt-oss:120b-cloud
# MIZAN_FETCH_PROVIDER=web

# ── HYBRID (grounding + stronger brain): gemini fetches real sourced facts, then the ──
#    main provider (e.g. ollama gpt-oss:120b) structures them. Set BOTH:
# MIZAN_PROVIDER=ollama
# OLLAMA_HOST=https://ollama.com
# OLLAMA_API_KEY=
# MIZAN_MODEL=gpt-oss:120b
# MIZAN_FETCH_PROVIDER=gemini           # turns on hybrid; needs GEMINI_API_KEY above
# GEMINI_API_KEY=

# ── LOCAL Ollama — your own machine, fully free/offline (qwen3:8b etc.), no key ──
# MIZAN_PROVIDER=ollama
# OLLAMA_HOST=http://localhost:11434
# MIZAN_MODEL=qwen3:8b

# ── Groq — fastest, free, no card (no grounding; feed it fetched text) ──
#    Key: https://console.groq.com/keys   (~30 req/min, ~1K/day)
# MIZAN_PROVIDER=groq
# GROQ_API_KEY=
# MIZAN_MODEL=llama-3.3-70b-versatile

# ── OpenRouter — many big :free models (~50 req/day) ──
#    Key: https://openrouter.ai/keys
# MIZAN_PROVIDER=openrouter
# OPENROUTER_API_KEY=
# MIZAN_MODEL=meta-llama/llama-3.3-70b-instruct:free
