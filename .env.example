# UAE Stocks Intelligence — environment (all optional; defaults are free + offline)

# Exchange data lane: mock (default) | live
UAE_PROVIDER=mock

# AI narration lane: stub (default, free+offline) | claude (free owned lane) | openai
UAE_AI_PROVIDER=stub
# Optional model override for the claude/openai lanes
# UAE_AI_MODEL=

# Optional paid lane — only used when UAE_AI_PROVIDER=openai
# OPENAI_API_KEY=

# Optional live World Bank commodity CSV (series,label,value,unit[,change_pct])
# WB_PINKSHEET_CSV_URL=

# Hard gate for ADX/DFM headless scraping + public deploy. Leave 0 until Khalid explicitly
# approves the data-rights/licensing posture.
# UAE_ALLOW_LIVE_EXCHANGE=0

# Per-exchange live enablement (only honoured once the endpoint is verified+licensed)
# ENABLE_ADX_LIVE=0
# ENABLE_DFM_LIVE=0

# Deploy target (GitHub Pages repo for the built site)
# PAGES_REPO=khaloodalbastaki-beep/uae-stocks-pages
# DATA_REPO=khaloodalbastaki-beep/uae-stocks-data
